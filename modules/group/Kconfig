comment "TLS group modules (Y=built-in, M=module, N=disabled)"
	depends on MODULES

config CRYPTO_GROUP_DYN_META
	tristate "TLS group identification table (ECC / FFDHE / PQ)"
	depends on MODULES
	select CRYPTO_GROUP
	default m
	help
	  Group identification metadata, loadable module.

config CRYPTO_GROUP_DYN_X25519_GENERIC
	tristate "X25519 (generic C, fiat)"
	depends on MODULES
	select CRYPTO_GROUP
	default m
	help
	  Portable X25519 key exchange, loadable module.

config CRYPTO_GROUP_DYN_X25519_AWS_X86_64
	tristate "X25519 (aws-lc s2n-bignum, x86_64)"
	depends on MODULES && CC_CPU_ACCELERATION && SRCARCH = "x86"
	select CRYPTO_GROUP
	default m
	help
	  aws-lc s2n-bignum x86_64 X25519, loadable module.

config CRYPTO_GROUP_DYN_X25519_AWS_ARMV8
	tristate "X25519 (aws-lc s2n-bignum, ARMv8)"
	depends on MODULES && CC_CPU_ACCELERATION && SRCARCH = "arm64"
	select CRYPTO_GROUP
	default m
	help
	  aws-lc s2n-bignum ARMv8 X25519, loadable module.

config CRYPTO_GROUP_DYN_SECP256R1_AWS_X86_64
