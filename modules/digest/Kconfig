menu "Digest algorithms"

config CRYPTO_SHA3
	bool

config CRYPTO_SHA3_NULL
	bool

config CRYPTO_SHA3_OSSL_X86_64
	bool

config CRYPTO_SHA3_OSSL_ARMV8
	bool

config CRYPTO_SHA3_OSSL_X86_64_AVX2
	bool

config CRYPTO_SHA3_AWS_X86_64
	bool

config CRYPTO_SHA3_AWS_ARMV8
	bool

choice
	prompt "SHA-3 implementation"
	depends on !MODULES
	default CRYPTO_SHA3_SEL_AWS_X86_64 if CRYPTO_VERIFIED && CC_CPU_ACCELERATION && SRCARCH = "x86"
	default CRYPTO_SHA3_SEL_AWS_ARMV8 if CRYPTO_VERIFIED && CC_CPU_ACCELERATION && SRCARCH = "arm64"
	default CRYPTO_SHA3_SEL_OSSL_X86_64 if !CRYPTO_VERIFIED && CC_CPU_ACCELERATION && SRCARCH = "x86"
	default CRYPTO_SHA3_SEL_OSSL_ARMV8 if !CRYPTO_VERIFIED && CC_CPU_ACCELERATION && SRCARCH = "arm64"
	default CRYPTO_SHA3_SEL_C
	help
	  Select the SHA-3 digest implementation to use. Only one
	  implementation can be active at a time.

config CRYPTO_SHA3_SEL_NULL
	bool "None"
	select CRYPTO_SHA3_NULL
	help
	  Do not include SHA-3 support.

config CRYPTO_SHA3_SEL_C
	bool "SHA-3 (generic)"
	depends on !MODULES && !CRYPTO_VERIFIED
	select CRYPTO_SHA3
	help
	  SHA-3 secure hash standard (FIPS 202) plain C implementation.

config CRYPTO_SHA3_SEL_OSSL_X86_64
	bool "SHA-3 (assembly, OpenSSL, x86_64)"
	depends on !MODULES && !CRYPTO_VERIFIED && CC_CPU_ACCELERATION
	depends on SRCARCH = "x86"
	select CRYPTO_SHA3_OSSL_X86_64
	help
	  SHA-3 Keccak-f[1600] using OpenSSL's platform-optimized
	  assembly for x86_64.

config CRYPTO_SHA3_SEL_OSSL_ARMV8
	bool "SHA-3 (assembly, OpenSSL, ARMv8)"
	depends on !MODULES && !CRYPTO_VERIFIED && CC_CPU_ACCELERATION
	depends on SRCARCH = "arm64"
	select CRYPTO_SHA3_OSSL_ARMV8
	help
	  SHA-3 Keccak-f[1600] using OpenSSL's platform-optimized
	  assembly for ARMv8.

config CRYPTO_SHA3_SEL_OSSL_X86_64_AVX2
	bool "SHA-3 (assembly, OpenSSL, x86_64, AVX2)"
	depends on !MODULES && !CRYPTO_VERIFIED && CC_CPU_ACCELERATION
	depends on SRCARCH = "x86"
	depends on X86_HAS_AVX2
	select CRYPTO_SHA3_OSSL_X86_64_AVX2
	help
	  SHA-3 Keccak-f[1600] using OpenSSL's AVX2-optimized assembly
	  for x86_64.

config CRYPTO_SHA3_SEL_AWS_X86_64
	bool "SHA-3 (assembly, aws-lc, x86_64)"
	depends on !MODULES && CC_CPU_ACCELERATION
	depends on SRCARCH = "x86"
	select CRYPTO_SHA3_AWS_X86_64
	help
	  SHA-3 Keccak-f[1600] permutation using optimized assembly
	  from aws-lc for x86_64.

config CRYPTO_SHA3_SEL_AWS_ARMV8
	bool "SHA-3 (assembly, aws-lc, ARMv8)"
	depends on !MODULES && CC_CPU_ACCELERATION
	depends on SRCARCH = "arm64"
	select CRYPTO_SHA3_AWS_ARMV8
	help
	  SHA-3 Keccak-f[1600] permutation using optimized assembly
	  from aws-lc for ARMv8.

endchoice

comment "SHA-3 modules (Y=built-in, M=module, N=disabled)"
	depends on MODULES

config CRYPTO_SHA3_DYN_C
	tristate "SHA-3 (generic)"
	depends on MODULES && !CRYPTO_VERIFIED
	default m
	help
	  SHA-3 secure hash standard (FIPS 202) plain C implementation.

