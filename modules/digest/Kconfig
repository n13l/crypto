config CRYPTO_SHA2_GENERIC
	bool

config CRYPTO_SHA2_NULL
	bool

config CRYPTO_SHA2_OSSL_X86_64
	bool

config CRYPTO_SHA2_OSSL_ARMV8
	bool

config CRYPTO_SHA2_AWS_X86_64
	bool

config CRYPTO_SHA2_AWS_X86_64_AVX
	bool

config CRYPTO_SHA2_AWS_X86_64_SHANI
	bool

config CRYPTO_SHA2_AWS_ARMV8
	bool

choice
	prompt "SHA-2 implementation"
	depends on !MODULES
	default CRYPTO_SHA2_SEL_AWS_ARMV8 if CRYPTO_VERIFIED && SRCARCH = "arm64"
	default CRYPTO_SHA2_SEL_AWS_X86_64_SHANI if CRYPTO_VERIFIED && SRCARCH = "x86"
	default CRYPTO_SHA2_SEL_OSSL_X86_64 if SRCARCH = "x86"
	default CRYPTO_SHA2_SEL_OSSL_ARMV8 if SRCARCH = "arm64"
	help
	  Select the SHA-2 (SHA-256/SHA-512) digest implementation to use.

config CRYPTO_SHA2_SEL_NULL
	bool "None"
	select CRYPTO_SHA2_NULL
	help
	  Do not include SHA-2 support.

config CRYPTO_SHA2_SEL_GENERIC
	bool "SHA-2 (generic)"
	select CRYPTO_SHA2_GENERIC
	help
	  Generic SHA-2 support.

config CRYPTO_SHA2_SEL_OSSL_X86_64
	bool "SHA-2 (assembly, OpenSSL, x86_64)"
	depends on !MODULES && CC_CPU_ACCELERATION
	depends on SRCARCH = "x86"
	select CRYPTO_SHA2_OSSL_X86_64
	help
	  SHA-256/SHA-512 using OpenSSL's platform-optimized assembly
	  for x86_64.

config CRYPTO_SHA2_SEL_OSSL_ARMV8
	bool "SHA-2 (assembly, OpenSSL, ARMv8)"
	depends on !MODULES && CC_CPU_ACCELERATION
	depends on SRCARCH = "arm64"
	select CRYPTO_SHA2_OSSL_ARMV8
	help
	  SHA-256/SHA-512 using OpenSSL's platform-optimized assembly
	  for ARMv8.

config CRYPTO_SHA2_SEL_AWS_X86_64
	bool "SHA-2 (assembly, aws-lc, x86_64)"
	depends on !MODULES && CC_CPU_ACCELERATION
	depends on SRCARCH = "x86"
	select CRYPTO_SHA2_AWS_X86_64
	help
	  SHA-256/SHA-512 using aws-lc baseline assembly for x86_64.

config CRYPTO_SHA2_SEL_AWS_X86_64_AVX
	bool "SHA-2 (assembly, aws-lc, x86_64, AVX)"
	depends on !MODULES && CC_CPU_ACCELERATION
	depends on SRCARCH = "x86"
	depends on X86_HAS_AVX
	select CRYPTO_SHA2_AWS_X86_64_AVX
	help
	  SHA-256/SHA-512 using aws-lc AVX-optimized assembly for x86_64.

config CRYPTO_SHA2_SEL_AWS_X86_64_SHANI
	bool "SHA-2 (assembly, aws-lc, x86_64, SHA-NI)"
	depends on !MODULES && CC_CPU_ACCELERATION
	depends on SRCARCH = "x86"
	depends on X86_HAS_SHA_NI
	select CRYPTO_SHA2_AWS_X86_64_SHANI
	help
	  SHA-256 using aws-lc SHA-NI hardware instructions for x86_64.
	  SHA-512 uses baseline (no SHA-NI for SHA-512).

config CRYPTO_SHA2_SEL_AWS_ARMV8
	bool "SHA-2 (assembly, aws-lc, ARMv8)"
	depends on !MODULES && CC_CPU_ACCELERATION
	depends on SRCARCH = "arm64"
	select CRYPTO_SHA2_AWS_ARMV8
	help
	  SHA-256/SHA-512 using aws-lc optimized assembly for ARMv8.

endchoice

