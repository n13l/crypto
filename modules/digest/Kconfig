config CRYPTO_SHA3_DYN_AWS_X86_64
	tristate "SHA-3 (assembly, aws-lc, x86_64)"
	depends on MODULES && CC_CPU_ACCELERATION
	depends on SRCARCH = "x86"
	default m
	help
	  SHA-3 Keccak-f[1600] permutation using optimized assembly
	  from aws-lc for x86_64.

config CRYPTO_SHA3_DYN_AWS_ARMV8
	tristate "SHA-3 (assembly, aws-lc, ARMv8)"
	depends on MODULES && CC_CPU_ACCELERATION
	depends on SRCARCH = "arm64"
	default m
	help
	  SHA-3 Keccak-f[1600] permutation using optimized assembly
	  from aws-lc for ARMv8.

config CRYPTO_SHA1_GENERIC
	bool

config CRYPTO_SHA1_NULL
	bool

config CRYPTO_SHA1_OSSL_X86_64
	bool

config CRYPTO_SHA1_OSSL_ARMV8
	bool

config CRYPTO_SHA1_AWS_X86_64
	bool

config CRYPTO_SHA1_AWS_X86_64_AVX
	bool

config CRYPTO_SHA1_AWS_X86_64_AVX2
	bool

config CRYPTO_SHA1_AWS_X86_64_SHANI
	bool

config CRYPTO_SHA1_AWS_ARMV8
	bool

choice
	prompt "SHA-1 implementation"
	depends on !MODULES
	default CRYPTO_SHA1_SEL_AWS_ARMV8 if CRYPTO_VERIFIED && CC_CPU_ACCELERATION && SRCARCH = "arm64"
	default CRYPTO_SHA1_SEL_AWS_X86_64_SHANI if CRYPTO_VERIFIED && CC_CPU_ACCELERATION && SRCARCH = "x86"
	default CRYPTO_SHA1_SEL_OSSL_X86_64 if !CRYPTO_VERIFIED && CC_CPU_ACCELERATION && SRCARCH = "x86"
	default CRYPTO_SHA1_SEL_OSSL_ARMV8 if !CRYPTO_VERIFIED && CC_CPU_ACCELERATION && SRCARCH = "arm64"
	default CRYPTO_SHA1_SEL_GENERIC if !CC_CPU_ACCELERATION
	help
	  Select the SHA-1 digest implementation to use.

config CRYPTO_SHA1_SEL_NULL
	bool "SHA-1 (none)"
	select CRYPTO_SHA1_NULL
	help
	  Do not include SHA-1 support.

config CRYPTO_SHA1_SEL_GENERIC
	bool "SHA-1 (generic)"
	depends on !MODULES
	select CRYPTO_SHA1_GENERIC
	help
	  Generic SHA-1 support.

config CRYPTO_SHA1_SEL_OSSL_X86_64
	bool "SHA-1 (assembly, OpenSSL, x86_64)"
	depends on !MODULES && CC_CPU_ACCELERATION
	depends on SRCARCH = "x86"
	select CRYPTO_SHA1_OSSL_X86_64
	help
	  SHA-1 using OpenSSL's platform-optimized assembly for x86_64.

config CRYPTO_SHA1_SEL_OSSL_ARMV8
	bool "SHA-1 (assembly, OpenSSL, ARMv8)"
	depends on !MODULES && CC_CPU_ACCELERATION
	depends on SRCARCH = "arm64"
	select CRYPTO_SHA1_OSSL_ARMV8
	help
	  SHA-1 using OpenSSL's platform-optimized assembly for ARMv8.

config CRYPTO_SHA1_SEL_AWS_X86_64
	bool "SHA-1 (assembly, aws-lc, x86_64)"
	depends on !MODULES && CC_CPU_ACCELERATION
	depends on SRCARCH = "x86"
	select CRYPTO_SHA1_AWS_X86_64
	help
	  SHA-1 using aws-lc baseline assembly for x86_64 (no HW extensions).

config CRYPTO_SHA1_SEL_AWS_X86_64_AVX
	bool "SHA-1 (assembly, aws-lc, x86_64, AVX)"
	depends on !MODULES && CC_CPU_ACCELERATION
	depends on SRCARCH = "x86"
	depends on X86_HAS_AVX
	select CRYPTO_SHA1_AWS_X86_64_AVX
