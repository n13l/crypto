# AES-128/256 (CBC, GCM)
obj-$(CONFIG_CRYPTO_CIPHER_AES_GENERIC) += aes/
obj-$(CONFIG_CRYPTO_CIPHER_AES_DYN_GENERIC) += aes/
obj-$(CONFIG_CRYPTO_CIPHER_AES_AWS_X86_64) += aes-aws-x86_64/
obj-$(CONFIG_CRYPTO_CIPHER_AES_DYN_AWS_X86_64) += aes-aws-x86_64/
obj-$(CONFIG_CRYPTO_CIPHER_AES_AWS_ARMV8) += aes-aws-armv8/
obj-$(CONFIG_CRYPTO_CIPHER_AES_DYN_AWS_ARMV8) += aes-aws-armv8/

# ChaCha20-Poly1305 (RFC 7539)
obj-$(CONFIG_CRYPTO_CIPHER_CHACHA20_GENERIC) += chacha/
obj-$(CONFIG_CRYPTO_CIPHER_CHACHA20_DYN_GENERIC) += chacha/
obj-$(CONFIG_CRYPTO_CIPHER_CHACHA20_AWS_X86_64) += chacha-aws-x86_64/
obj-$(CONFIG_CRYPTO_CIPHER_CHACHA20_DYN_AWS_X86_64) += chacha-aws-x86_64/
obj-$(CONFIG_CRYPTO_CIPHER_CHACHA20_AWS_ARMV8) += chacha-aws-armv8/
obj-$(CONFIG_CRYPTO_CIPHER_CHACHA20_DYN_AWS_ARMV8) += chacha-aws-armv8/
