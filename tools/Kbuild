# crypto command-line tools.
#
# Correctness tools (one per primitive): each links the crypto algorithm
# archive and checks its NIST/RFC known-answer vectors against whichever
# backend the build selected, printing "<name>: ok/FAIL" and exiting non-zero
# on failure. CRYPTO_DIR names the package sources and CRYPTO_MODULES the
# module build dir, so the paths work both standalone (./modules) and hosted
# under a parent project.
testprogs-y := digest cipher hmac prf hkdf
TEST_CFLAGS = -I$(srctree)/$(CRYPTO_DIR)/modules/digest/sha3-ossl
LIBS_digest = $(CRYPTO_MODULES)/built-in.o
LIBS_cipher = $(CRYPTO_MODULES)/built-in.o
LIBS_hmac   = $(CRYPTO_MODULES)/built-in.o
LIBS_prf    = $(CRYPTO_MODULES)/built-in.o
LIBS_hkdf   = $(CRYPTO_MODULES)/built-in.o

# Performance benchmarks live under testing/perf.
subdir-y += testing/perf
